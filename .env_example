# LLM
OPENAI_API_KEY="EMPTY"
OPENAI_BASE_URL="http://localhost:6006/v1"
SMART_LLM_MODEL="Qwen3.5-27B"
CHEAP_LLM_MODEL="Qwen3.5-27B"

# Embedding
EMBEDDING_API_KEY="EMPTY"
EMBEDDING_BASE_URL="http://localhost:5005/v1"
EMBEDDING_MODEL_NAME="Qwen3-Embedding-8B"

# Reranker
RERANKER_API_KEY="EMPTY"
RERANKER_BASE_URL="http://localhost:7007/v1"
RERANKER_MODEL_NAME="Qwen3-Reranker-4B"

# Databases
NEO4J_URI="bolt://localhost:7687"
MILVUS_URI="http://localhost:19530"

# Novel parsing and chunking (non-sensitive)
NOVEL_RAW_FILE_PATH="/Path/to/data/raw/tsxk.txt"
NOVEL_FILE_ENCODING="gb18030"
HEADING_MAX_LINE_CHARS=40

CHUNK_MAX_TOKENS=800
SEMANTIC_BREAKPOINT_PERCENTILE=90
CONTEXT_INJECT_MAX_CONCURRENCY=20

# Tokenizer
LOCAL_TOKENIZER_PATH="/Path/to/tokenizer"

# Optional
PYTHONPATH="."
